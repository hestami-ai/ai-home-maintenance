---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  tags: string[];
  heroLabel?: string;
  readingTime?: string;
}

const { title, description, pubDate, author, tags, heroLabel, readingTime } = Astro.props;
---

<Base title={title} description={description}>
  <article class="blog-post">
    <header class="blog-post__hero section">
      <div class="container container--narrow">
        {heroLabel && <span class="section-header__label">{heroLabel}</span>}
        <h1 class="blog-post__title">{title}</h1>
        <div class="blog-post__meta">
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span class="blog-post__sep">·</span>
          <span>{author}</span>
          {readingTime && (
            <>
              <span class="blog-post__sep">·</span>
              <span>{readingTime}</span>
            </>
          )}
        </div>
        <div class="blog-post__tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      </div>
    </header>

    <div class="blog-post__content container container--narrow">
      <slot />
    </div>
  </article>
</Base>

<style>
  .blog-post__hero {
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }

  .blog-post__title {
    font-size: 2.75rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: var(--space-lg);
  }

  .blog-post__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .blog-post__sep {
    opacity: 0.4;
  }

  .blog-post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .blog-post__content {
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-4xl);
  }

  /* Prose styles for rendered markdown */
  .blog-post__content :global(h2) {
    font-size: 1.75rem;
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-lg);
    letter-spacing: -0.02em;
  }

  .blog-post__content :global(h3) {
    font-size: 1.25rem;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    letter-spacing: -0.01em;
  }

  .blog-post__content :global(p) {
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
    font-size: 1.05rem;
  }

  .blog-post__content :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .blog-post__content :global(em) {
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .blog-post__content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: rgba(0, 212, 255, 0.3);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.2s;
  }

  .blog-post__content :global(a:hover) {
    text-decoration-color: var(--color-primary);
  }

  .blog-post__content :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    background: var(--color-bg-elevated);
    padding: var(--space-lg) var(--space-xl);
    margin: var(--space-xl) 0;
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
  }

  .blog-post__content :global(blockquote p) {
    color: var(--color-text);
    font-size: 1.1rem;
    font-style: italic;
    margin-bottom: 0;
  }

  .blog-post__content :global(ul),
  .blog-post__content :global(ol) {
    margin: var(--space-lg) 0;
    padding-left: var(--space-xl);
  }

  .blog-post__content :global(li) {
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-sm);
    font-size: 1.05rem;
  }

  .blog-post__content :global(li::marker) {
    color: var(--color-primary);
  }

  .blog-post__content :global(hr) {
    border: none;
    height: 1px;
    background: var(--color-border);
    margin: var(--space-3xl) 0;
  }

  .blog-post__content :global(pre) {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    overflow-x: auto;
    margin: var(--space-xl) 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.7;
  }

  .blog-post__content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-card);
    padding: 0.15em 0.4em;
    border-radius: var(--radius-sm);
    color: var(--color-primary);
  }

  .blog-post__content :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .blog-post__title {
      font-size: 1.75rem;
    }
    .blog-post__meta {
      flex-wrap: wrap;
    }
  }
</style>
