---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "JanumiCode — Governed, auditable AI-assisted software development." } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/how-it-works", label: "HOW IT WORKS" },
  { href: "/architecture", label: "ARCHITECTURE" },
  { href: "/enterprise", label: "ENTERPRISE" },
  { href: "/case-study", label: "CASE STUDY" },
  { href: "/gallery", label: "GALLERY" },
  { href: "/blog", label: "BLOG" },
];

const marketplaceUrl = "https://marketplace.visualstudio.com/items?itemName=hestami.janumicode";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | JanumiCode</title>
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <nav class="nav">
    <div class="container nav__inner">
      <a href="/" class="nav__brand">
        <img src="/logo.png" alt="JanumiCode" class="nav__logo" />
        <span class="nav__name">JanumiCode</span>
      </a>
      <div class="nav__links">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={["nav__link", { "nav__link--active": currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
          >
            {link.label}
          </a>
        ))}
      </div>
      <a href={marketplaceUrl} class="btn btn--primary nav__cta" target="_blank" rel="noopener">
        Install Extension
      </a>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__top">
        <div class="footer__brand">
          <div class="footer__brand-name">JANUMICODE</div>
          <p class="footer__tagline">Building the future of governed autonomous<br />engineering. AI-native toolkits for trustworthy<br />software development.</p>
          <a href={marketplaceUrl} class="btn btn--secondary btn--sm" target="_blank" rel="noopener">Get Started</a>
        </div>
        <div class="footer__links">
          <div class="footer__col">
            <h4 class="footer__heading">Resources</h4>
            <a href="/architecture" class="footer__link">Architecture</a>
            <a href="/how-it-works" class="footer__link">API Reference</a>
            <a href="/enterprise" class="footer__link">Enterprise</a>
            <a href="/blog" class="footer__link">Blog</a>
          </div>
          <div class="footer__col">
            <h4 class="footer__heading">Company</h4>
            <a href="/case-study" class="footer__link">Case Study</a>
            <a href={marketplaceUrl} class="footer__link" target="_blank" rel="noopener">VS Code Marketplace</a>
            <a href="https://github.com/hestami-ai" class="footer__link" target="_blank" rel="noopener">GitHub</a>
          </div>
        </div>
      </div>
      <div class="footer__bottom">
        <p>&copy; {new Date().getFullYear()} Hestami AI. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<style>
  /* Navigation */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(6, 11, 20, 0.9);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
  }

  .nav__logo {
    width: 28px;
    height: 28px;
    border-radius: 4px;
  }

  .nav__name {
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .nav__links {
    display: flex;
    gap: var(--space-xl);
  }

  .nav__link {
    font-size: 0.7rem;
    font-weight: 600;
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .nav__link:hover {
    color: var(--color-primary);
  }

  .nav__link--active {
    color: var(--color-primary);
  }

  .nav__cta {
    font-size: 0.75rem;
    padding: 0.4rem 0.9rem;
  }

  /* Main content offset for fixed nav */
  main {
    padding-top: 56px;
  }

  /* Footer */
  .footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-3xl) 0 var(--space-lg);
    background: var(--color-bg);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .footer__top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3xl);
  }

  .footer__brand {
    max-width: 320px;
  }

  .footer__brand-name {
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .footer__tagline {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-lg);
  }

  .btn--sm {
    font-size: 0.75rem;
    padding: 0.35rem 0.8rem;
  }

  .footer__links {
    display: flex;
    gap: var(--space-4xl);
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer__heading {
    font-size: 0.65rem;
    font-weight: 600;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .footer__link {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .footer__link:hover {
    color: var(--color-primary);
  }

  .footer__bottom {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
  }

  .footer__bottom p {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none;
    }
    .footer__top {
      flex-direction: column;
    }
    .footer__links {
      flex-direction: column;
      gap: var(--space-xl);
    }
  }
</style>
