---
import Base from "../layouts/Base.astro";
---

<Base title="Governed Stream Gallery" description="Interactive CSS/HTML recreations of the JanumiCode Governed Stream UI.">

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-header__label">UI Gallery</span>
        <h2>Governed Stream</h2>
        <p>Interactive CSS/HTML recreations of the JanumiCode Governed Stream WebView — the real-time workspace inside VS Code where every agent action, human decision, and verification result is surfaced.</p>
      </div>
    </div>
  </section>

  <!-- Screenshot 1: INTAKE Analysis Session -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-header__label">Intake &mdash; Document Analysis</span>
        <h2>Product description intake with<br />reasoning review</h2>
        <p>A governed stream session showing JanumiCode analyzing the Hestami AI Real Property OS product description — from classification through mode selection, analysis, and reasoning review.</p>
      </div>

      <!-- ═══ Governed Stream Recreation ═══ -->
      <div class="gs">
        <!-- Top Bar -->
        <div class="gs__topbar">
          <div class="gs__topbar-left">
            <span class="gs__topbar-title">GOVERNED STREAM TIMELINE</span>
          </div>
          <div class="gs__topbar-right">
            <span class="gs__topbar-action">Supervisions</span>
            <span class="gs__topbar-action">Reasoning Reviews (3)</span>
          </div>
        </div>

        <!-- Phase Progress Bar -->
        <div class="gs__phase-bar">
          <div class="gs__phase-step gs__phase-step--active">
            <span class="gs__phase-dot gs__phase-dot--active"></span>
            <span>INTAKE</span>
          </div>
          <div class="gs__phase-step">
            <span class="gs__phase-dot"></span>
            <span>ARCHITECTURE</span>
          </div>
          <div class="gs__phase-step">
            <span class="gs__phase-dot"></span>
            <span>PROPOSE</span>
          </div>
          <div class="gs__phase-step">
            <span class="gs__phase-dot"></span>
            <span>EXECUTE</span>
          </div>
        </div>

        <!-- Stream Content -->
        <div class="gs__stream">

          <!-- System message -->
          <div class="gs__system-msg">
            <span class="gs__system-icon">&#9670;</span>
            <span>Review "<em>specifications in real-property-os/Hestami AI Real Property OS and Platform Product Description.md</em>" and prepare for implementation.</span>
          </div>

          <!-- Command Block: Intake Classifier -->
          <div class="gs__cmd">
            <div class="gs__cmd-header">
              <span class="gs__cmd-icon">&#9670;</span>
              <span class="gs__cmd-label">Intake &mdash; Classifier</span>
              <span class="gs__badge gs__badge--cli">CLI</span>
              <span class="gs__cmd-time">11:28:14 AM</span>
            </div>
          </div>

          <!-- Status Card: INTAKE Mode -->
          <div class="gs__status-card">
            <div class="gs__status-card-header">
              <span class="gs__status-icon gs__status-icon--info">&#9432;</span>
              <span class="gs__status-title">INTAKE Mode: Document Based</span>
            </div>
            <div class="gs__status-card-body">
              <p>Activating: Review "<em>specifications in real-property-os/Hestami AI Real Property OS and Platform Product Description.md</em>" for &lt;hint: property-os and platform product-description&gt; and prepare for implementation.</p>
              <div class="gs__status-tags">
                <span class="gs__tag gs__tag--cyan">Mode: DOCUMENT_BASED</span>
                <span class="gs__tag gs__tag--dim">Turns: 0/8 for full analysis</span>
                <span class="gs__tag gs__tag--dim">Confidence: safe-to-proceed level</span>
              </div>
            </div>
          </div>

          <!-- Command Block: Context Engineer -->
          <div class="gs__cmd">
            <div class="gs__cmd-header">
              <span class="gs__cmd-icon">&#9670;</span>
              <span class="gs__cmd-label">Context Engineer &mdash; TECHNICAL_EXPERT:INTAKE</span>
              <span class="gs__badge gs__badge--cli">CLI</span>
              <span class="gs__badge gs__badge--review">&#128270; Review</span>
              <span class="gs__cmd-time">11:28:22 AM</span>
            </div>
            <div class="gs__cmd-body">
              <div class="gs__cmd-output">Completed (success)</div>
            </div>
          </div>

          <!-- Command Block: Technical Expert - INTAKE Analysis -->
          <div class="gs__cmd gs__cmd--expanded">
            <div class="gs__cmd-header">
              <span class="gs__cmd-icon">&#9670;</span>
              <span class="gs__cmd-label">Technical Expert &mdash; INTAKE (analysis)</span>
              <span class="gs__badge gs__badge--cli">CLI</span>
              <span class="gs__badge gs__badge--review">&#128270; Review</span>
              <span class="gs__cmd-time">11:29:05 AM</span>
            </div>
            <div class="gs__cmd-body">
              <div class="gs__cmd-content">
                <h4 class="gs__analysis-title">Architecture Analysis</h4>
                <p class="gs__analysis-text">
                  You have provided a comprehensive product description for a very large scale platform named "Hestami AI Real Property OS and Platform." The system is designed as an integrated, end-to-end real-property and home services platform composed of three major pillars: (1) Hestami Home Real Property Assistant, (2) Hestami Service Provider Field Services Management, and (3) Hestami Community Association Management, modeled after ServiceTitan and Vantaca respectively.
                </p>
                <p class="gs__analysis-text">
                  The product is built on a modern tech stack: SvelteKit frontend, Bun for the Node.js backend, PostgreSQL with Row-Level Security (RLS) for multi-tenant isolation, DBOS for durable versioned workflows, oRPC for the API layer, Cerbos for policy-based authorization, and Better-Auth for authentication. The document includes a 12-domain Common Data Model (CDM), persona definitions, user journeys, and a phased delivery strategy.
                </p>
                <p class="gs__analysis-text">
                  While the document is comprehensive in scope, the strategic, vision and technical architecture are well defined. The document does however leave specific implementation details to be discovered and decided during the Architecture and Execution phases. This is appropriate for a document of this nature and scope.
                </p>
                <p class="gs__analysis-text gs__analysis-text--highlight">
                  I recommend we take a systematic, building-block approach to implementation priorities and quality, and setting up the foundational infrastructure based on the prescribed technology stack.
                </p>
              </div>
              <div class="gs__cmd-footer">
                <span class="gs__status gs__status--success">Completed (success)</span>
              </div>
            </div>
          </div>

          <!-- Reasoning Review 1 -->
          <div class="gs__review">
            <div class="gs__review-header">
              <span class="gs__review-icon">&#128270;</span>
              <span class="gs__review-title">Reasoning Review</span>
              <span class="gs__review-severity gs__review-severity--medium">MEDIUM</span>
            </div>
            <div class="gs__review-body">
              <p class="gs__review-concern">The agent provides a solid, high-level summary of the overall product surface. However, it would be beneficial for the expert to also reference any specific prior context, in-repository code, infrastructure/tooling conventions, or similar existing artifacts so that its analysis anchors to observable evidence rather than only the submitted document.</p>
            </div>
            <div class="gs__review-footer">
              <span class="gs__review-meta">Proposing business analysis and services</span>
            </div>
          </div>

          <!-- Reasoning Review 2 -->
          <div class="gs__review">
            <div class="gs__review-header">
              <span class="gs__review-icon">&#128270;</span>
              <span class="gs__review-title">Reasoning Review</span>
              <span class="gs__review-severity gs__review-severity--high">HIGH</span>
            </div>
            <div class="gs__review-body">
              <div class="gs__review-concern-block">
                <span class="gs__review-concern-icon gs__review-concern-icon--warn">&#9888;</span>
                <p class="gs__review-concern">The agent failed to produce any domains, a primary requirement of the task.</p>
              </div>
              <div class="gs__review-concern-block">
                <span class="gs__review-concern-icon gs__review-concern-icon--warn">&#9888;</span>
                <p class="gs__review-concern">The agent omitted multiple domain elements from the source document instead of proposing them individually.</p>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ -->
  <!--  Screenshot 2: Proposed Business Domains           -->
  <!-- ═══════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-header__label">Intake &mdash; Proposer Round 1</span>
        <h2>Proposed business domains</h2>
        <p>The Domain Proposer analyzes the product description and generates business domain proposals, each tagged with its source attribution.</p>
      </div>

      <div class="gs">
        <div class="gs__topbar">
          <div class="gs__topbar-left"><span class="gs__topbar-title">GOVERNED STREAM TIMELINE</span></div>
          <div class="gs__topbar-right"><span class="gs__topbar-action">Review Domains of Real Property OS</span></div>
        </div>
        <div class="gs__phase-bar">
          <div class="gs__phase-step gs__phase-step--active"><span class="gs__phase-dot gs__phase-dot--active"></span><span>INTAKE</span></div>
          <div class="gs__phase-step"><span class="gs__phase-dot"></span><span>ARCHITECTURE</span></div>
          <div class="gs__phase-step"><span class="gs__phase-dot"></span><span>PROPOSE</span></div>
          <div class="gs__phase-step"><span class="gs__phase-dot"></span><span>EXECUTE</span></div>
        </div>

        <div class="gs__stream">
          <div class="gs__system-msg">
            <span class="gs__system-icon">&#9670;</span>
            <span><strong>Proposed Business Domains</strong> &mdash; Review each domain below, a draft plan</span>
          </div>

          <!-- Sub-phase indicator -->
          <div class="gs__subphase-bar">
            <span class="gs__subphase gs__subphase--active">Domains &amp; Personas</span>
            <span class="gs__subphase">Journeys &amp; Workflows</span>
            <span class="gs__subphase">Entity &amp; Data Model</span>
            <span class="gs__subphase">Integrations &amp; Quality</span>
          </div>

          <!-- Domain list -->
          <div class="gs__domain-list">
            <div class="gs__domain-item">
              <div class="gs__domain-header">
                <span class="gs__domain-num">1</span>
                <span class="gs__domain-name">Property & Association Model</span>
                <span class="gs__source-tag gs__source-tag--doc">DOCUMENT-SPECIFIED</span>
              </div>
              <p class="gs__domain-desc">Defines the foundational structure and entity relationships, land associations, and their relationships: (I) owner/ownership, residence entity, common/social, legal parcels and organizations that own, manage or relate to and register their use, manage or enable their use.</p>
            </div>

            <div class="gs__domain-item">
              <div class="gs__domain-header">
                <span class="gs__domain-num">2</span>
                <span class="gs__domain-name">Accounting & Financial</span>
                <span class="gs__source-tag gs__source-tag--doc">DOCUMENT-SPECIFIED</span>
              </div>
              <p class="gs__domain-desc">Covers all financial operations including Chart of Accounts, General Ledger, Assessments, AR/AP, Payments, Journal Entries, Vendor W-9/1099 data, bank reconciliation, assessment charges, and financial reporting.</p>
            </div>

            <div class="gs__domain-item">
              <div class="gs__domain-header">
                <span class="gs__domain-num">3</span>
                <span class="gs__domain-name">Workflow Automation</span>
                <span class="gs__source-tag gs__source-tag--doc">DOCUMENT-SPECIFIED</span>
              </div>
              <p class="gs__domain-desc">Manages the lifecycle of all business processes. Covers task routing, SLA timers, event triggers, approval chains, and notification dispatch. Built on DBOS versioned workflows for durability and idempotent state transitions.</p>
            </div>

            <div class="gs__domain-item">
              <div class="gs__domain-header">
                <span class="gs__domain-num">4</span>
                <span class="gs__domain-name">Compliance & Violations</span>
                <span class="gs__source-tag gs__source-tag--doc">DOCUMENT-SPECIFIED</span>
              </div>
              <p class="gs__domain-desc">Manages HOA violation lifecycle including evidence capture (photos, videos), notice sequences, hearings, fine assessment with GL posting, and appeal workflows. Also covers statutory deadline tracking and voting rule compliance.</p>
            </div>

            <div class="gs__domain-item">
              <div class="gs__domain-header">
                <span class="gs__domain-num">5</span>
                <span class="gs__domain-name">Architectural Review (ARC)</span>
                <span class="gs__source-tag gs__source-tag--doc">DOCUMENT-SPECIFIED</span>
              </div>
              <p class="gs__domain-desc">Covers ARC requests, plan/document submission, committee review and conditional approvals, permit/BLDS integration for construction and modifications to the property, managing the submission, review, and decision process for architectural modifications.</p>
            </div>

            <div class="gs__domain-item">
              <div class="gs__domain-header">
                <span class="gs__domain-num">6</span>
                <span class="gs__domain-name">Work Orders & Maintenance</span>
                <span class="gs__source-tag gs__source-tag--doc">DOCUMENT-SPECIFIED</span>
              </div>
              <p class="gs__domain-desc">Manages the full lifecycle of maintenance and repair work. Covers work order creation, asset tracking, vendor assignment, bid/proposal management, scheduling, completion tracking, and invoice-to-AP workflow integration.</p>
            </div>

            <div class="gs__domain-item">
              <div class="gs__domain-header">
                <span class="gs__domain-num">7</span>
                <span class="gs__domain-name">Communication & Notifications</span>
                <span class="gs__source-tag gs__source-tag--doc">DOCUMENT-SPECIFIED</span>
              </div>
              <p class="gs__domain-desc">Manages all outbound communications: mass email, SMS, announcements, letter templates, calendar events, meeting notices, and role-based messaging. Integrates across all pillars for unified notification dispatch.</p>
            </div>

            <div class="gs__domain-item">
              <div class="gs__domain-header">
                <span class="gs__domain-num">8</span>
                <span class="gs__domain-name">Governance & Board Management</span>
                <span class="gs__source-tag gs__source-tag--doc">DOCUMENT-SPECIFIED</span>
              </div>
              <p class="gs__domain-desc">Manages the full lifecycle of association board governance: meetings, agendas, minutes, voting, resolutions, policy documents, board roles, and committee management.</p>
            </div>

            <div class="gs__domain-item">
              <div class="gs__domain-header">
                <span class="gs__domain-num">9</span>
                <span class="gs__domain-name">Contractor Identity & Licensing</span>
                <span class="gs__source-tag gs__source-tag--std">DOMAIN-STANDARD</span>
              </div>
              <p class="gs__domain-desc">Defines contractor legal/operational profiles: licensing, certifications, insurance, bonding, business classifications, operating hours, branch locations, approved vendor status. AI-driven license expiration and compliance monitoring.</p>
            </div>

            <div class="gs__domain-item">
              <div class="gs__domain-header">
                <span class="gs__domain-num">10</span>
                <span class="gs__domain-name">Field Service Operations</span>
                <span class="gs__source-tag gs__source-tag--std">DOMAIN-STANDARD</span>
              </div>
              <p class="gs__domain-desc">Covers dispatch, routing, scheduling, mobile technician operations, on-site estimate generation, payment acceptance, voice notes, before/after documentation, and offline-first capabilities for low-connectivity field work.</p>
            </div>

            <div class="gs__domain-item">
              <div class="gs__domain-header">
                <span class="gs__domain-num">11</span>
                <span class="gs__domain-name">Pricebook & Commercial</span>
                <span class="gs__source-tag gs__source-tag--std">DOMAIN-STANDARD</span>
              </div>
              <p class="gs__domain-desc">Defines the commercial catalog: service items, labor models (flat rate, hourly), materials, bundles, job templates, seasonal pricing, volume pricing, versioned pricebook updates. All estimates and invoices derive from pricebook definitions.</p>
            </div>

            <div class="gs__domain-item">
              <div class="gs__domain-header">
                <span class="gs__domain-num">12</span>
                <span class="gs__domain-name">Document & Trust Ledger</span>
                <span class="gs__source-tag gs__source-tag--doc">DOCUMENT-SPECIFIED</span>
              </div>
              <p class="gs__domain-desc">Covers document management (CC&Rs, bylaws, rules, contracts, reserve studies, inspection reports) with AI-driven extraction, classification, and summarization. Includes the Decision, Rationale & Trust Ledger for transparent recording of material decisions.</p>
            </div>

            <div class="gs__domain-item">
              <div class="gs__domain-header">
                <span class="gs__domain-num">13</span>
                <span class="gs__domain-name">Platform Identity & Auth</span>
                <span class="gs__source-tag gs__source-tag--ai">AI-PROPOSED</span>
              </div>
              <p class="gs__domain-desc">Cross-cutting authentication (Better-Auth) and policy-based authorization (Cerbos) layer. User accounts, role management (Owner, Tenant, Manager, Vendor, Board Member), session handling, and multi-tenant access control.</p>
            </div>

            <div class="gs__domain-item">
              <div class="gs__domain-header">
                <span class="gs__domain-num">14</span>
                <span class="gs__domain-name">Media & Digital Assets</span>
                <span class="gs__source-tag gs__source-tag--ai">AI-PROPOSED</span>
              </div>
              <p class="gs__domain-desc">Manages the media pipeline: resumable uploads (tusd), malware scanning (ClamAV), video processing (ffmpeg), image derivatives (libvips), metadata extraction (ExifTool), and object storage (SeaweedFS).</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ -->
  <!--  Screenshot 3: Proposed Data Model                 -->
  <!-- ═══════════════════════════════════════════════════ -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-header__label">Intake &mdash; Proposer Round 3</span>
        <h2>Proposed data model</h2>
        <p>The Entity Proposer generates typed data entities with relationships, organized by domain. Each entity type is color-coded.</p>
      </div>

      <div class="gs">
        <div class="gs__topbar">
          <div class="gs__topbar-left"><span class="gs__topbar-title">GOVERNED STREAM TIMELINE</span></div>
          <div class="gs__topbar-right"><span class="gs__topbar-action">Proposer &mdash; Data Model</span></div>
        </div>
        <div class="gs__phase-bar">
          <div class="gs__phase-step gs__phase-step--active"><span class="gs__phase-dot gs__phase-dot--active"></span><span>INTAKE</span></div>
          <div class="gs__phase-step"><span class="gs__phase-dot"></span><span>ARCHITECTURE</span></div>
          <div class="gs__phase-step"><span class="gs__phase-dot"></span><span>PROPOSE</span></div>
          <div class="gs__phase-step"><span class="gs__phase-dot"></span><span>EXECUTE</span></div>
        </div>

        <div class="gs__stream">
          <div class="gs__system-msg">
            <span class="gs__system-icon">&#9670;</span>
            <span><strong>Proposed Data Model</strong> &mdash; Round 3 of 4 (Entities &amp; Relationships)</span>
          </div>

          <div class="gs__subphase-bar">
            <span class="gs__subphase gs__subphase--done">Domains &amp; Personas</span>
            <span class="gs__subphase gs__subphase--done">Journeys &amp; Workflows</span>
            <span class="gs__subphase gs__subphase--active">Entity &amp; Data Model</span>
            <span class="gs__subphase">Integrations &amp; Quality</span>
          </div>

          <!-- Domain: Property & Association Model -->
          <div class="gs__entity-domain">
            <div class="gs__entity-domain-header">
              <span class="gs__entity-domain-name">Property & Association Model</span>
              <span class="gs__entity-domain-count">8 entities</span>
            </div>
            <div class="gs__entity-list">
              <div class="gs__entity">
                <span class="gs__entity-type gs__entity-type--entity">Entity</span>
                <span class="gs__entity-name">Organization</span>
                <span class="gs__entity-desc">The highest-level legal entity, such as a Homeowners Association (HOA) or Community Association (COA), that governs a community.</span>
              </div>
              <div class="gs__entity">
                <span class="gs__entity-type gs__entity-type--entity">Entity</span>
                <span class="gs__entity-name">Property</span>
                <span class="gs__entity-desc">A physical property unit within an association, such as a single-family home, condominium unit, or lot.</span>
              </div>
              <div class="gs__entity">
                <span class="gs__entity-type gs__entity-type--entity">Entity</span>
                <span class="gs__entity-name">Person</span>
                <span class="gs__entity-desc">Represents an individual person, such as an owner, resident, board member or vendor contact.</span>
              </div>
              <div class="gs__entity">
                <span class="gs__entity-type gs__entity-type--relationship">Relationship</span>
                <span class="gs__entity-name">Ownership</span>
                <span class="gs__entity-desc">A junction entity linking a Person (owner) to a Property within an Association, defining the ownership structure and rights.</span>
              </div>
              <div class="gs__entity">
                <span class="gs__entity-type gs__entity-type--relationship">Relationship</span>
                <span class="gs__entity-name">Management Contract</span>
                <span class="gs__entity-desc">An association with a management company or individual.</span>
              </div>
            </div>
          </div>

          <!-- Domain: Accounting -->
          <div class="gs__entity-domain">
            <div class="gs__entity-domain-header">
              <span class="gs__entity-domain-name">Accounting & Financial</span>
              <span class="gs__entity-domain-count">6 entities</span>
            </div>
            <div class="gs__entity-list">
              <div class="gs__entity">
                <span class="gs__entity-type gs__entity-type--entity">Entity</span>
                <span class="gs__entity-name">Chart of Accounts</span>
                <span class="gs__entity-desc">The root classification of a Chart of Accounts (e.g., 'Homeowner Accounts', 'Repair Expenses', 'Reserve Fund').</span>
              </div>
              <div class="gs__entity">
                <span class="gs__entity-type gs__entity-type--entity">Entity</span>
                <span class="gs__entity-name">Journal Entry</span>
                <span class="gs__entity-desc">Represents double-entry bookkeeping transactions.</span>
              </div>
              <div class="gs__entity">
                <span class="gs__entity-type gs__entity-type--entity">Entity</span>
                <span class="gs__entity-name">Assessment</span>
                <span class="gs__entity-desc">A charge levied against a property by its HOA (e.g., periodic, special). Generating a debit or credit to an account.</span>
              </div>
              <div class="gs__entity">
                <span class="gs__entity-type gs__entity-type--enum">Enum</span>
                <span class="gs__entity-name">Ledger Transaction</span>
                <span class="gs__entity-desc">Discrete categories: Regular Assessment, Special Assessment, Fine, Vendor Payment, Refund.</span>
              </div>
            </div>
          </div>

          <!-- Domain: Compliance -->
          <div class="gs__entity-domain">
            <div class="gs__entity-domain-header">
              <span class="gs__entity-domain-name">Compliance & Violations</span>
              <span class="gs__entity-domain-count">5 entities</span>
            </div>
            <div class="gs__entity-list">
              <div class="gs__entity">
                <span class="gs__entity-type gs__entity-type--entity">Entity</span>
                <span class="gs__entity-name">Violation</span>
                <span class="gs__entity-desc">A recorded violation of community rules or CC&Rs against a specific property.</span>
              </div>
              <div class="gs__entity">
                <span class="gs__entity-type gs__entity-type--entity">Entity</span>
                <span class="gs__entity-name">Statutory Deadline</span>
                <span class="gs__entity-desc">A regulatory or statutory deadline that the association must comply with.</span>
              </div>
              <div class="gs__entity">
                <span class="gs__entity-type gs__entity-type--relationship">Relationship</span>
                <span class="gs__entity-name">Notice Sequence</span>
                <span class="gs__entity-desc">An ordered set of notice steps that must be followed for a violation. Linked to workflow automation.</span>
              </div>
              <div class="gs__entity">
                <span class="gs__entity-type gs__entity-type--entity">Entity</span>
                <span class="gs__entity-name">Hearing</span>
                <span class="gs__entity-desc">A formal communication and/or a meeting regarding a violation, often generated as a step in the violation workflow.</span>
              </div>
              <div class="gs__entity">
                <span class="gs__entity-type gs__entity-type--relationship">Relationship</span>
                <span class="gs__entity-name">Fine &rarr; GL</span>
                <span class="gs__entity-desc">A specific rule, carryover of regulations from the association's governing documents.</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ -->
  <!--  Screenshot 4: Domain Coverage                     -->
  <!-- ═══════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-header__label">Intake &mdash; Coverage Analysis</span>
        <h2>Domain coverage assessment</h2>
