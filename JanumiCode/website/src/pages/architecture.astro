---
import Base from "../layouts/Base.astro";

const agents = [
  {
    name: "Technical Expert",
    role: "Analysis & Design",
    description: "Analyzes product requirements, decomposes business domains, proposes architecture. Operates across INTAKE and ARCHITECTURE phases with sub-phase specialization (decomposing, designing, modeling, sequencing).",
    authority: "Proposes — never executes"
  },
  {
    name: "Executor",
    role: "Code Generation",
    description: "Generates and modifies code within bounded task units. Each unit is a small, verifiable piece of work with explicit file-level tool access. Generates claims about what was done for independent verification.",
    authority: "Executes — within bounded units only"
  },
  {
    name: "Verifier",
    role: "Independent Verification",
    description: "Evaluates every claim the Executor makes against evidence. Does not trust assertions — checks them. Produces verdicts: VERIFIED, CONDITIONAL, DISPROVED, or UNKNOWN. Operates independently of the Executor.",
    authority: "Judges — cannot modify code"
  },
  {
    name: "Historian",
    role: "Historical Analysis",
    description: "Queries the full decision history across dialogues. Checks for contradictions with prior decisions, searches for precedents, verifies architectural constraint compliance, and flags goal drift. Read-only — never modifies history.",
    authority: "Reads — never writes"
  },
  {
    name: "Context Engineer",
    role: "Context Assembly",
    description: "Assembles policy-driven context briefings for every role invocation. Looks up declarative policies, gathers handoff documents, applies token budgets, and ensures each agent has complete and correct information for its task.",
    authority: "Assembles — serves other agents"
  },
  {
    name: "Deep Research Memory Agent",
    role: "Memory Adjudication",
    description: "Multi-stage memory research across dialogues. Reconstructs materially relevant historical context with evidence, conflict handling, and provenance tracking. Six-stage pipeline: interpret, harvest, triage, drill-down, conflict analysis, synthesis.",
    authority: "Researches — enhances context"
  },
];
---

<Base title="Architecture" description="Multi-agent roles, context engineering, and data flow in JanumiCode.">
  <!-- Agents -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-header__label">Multi-Agent Architecture</span>
        <h2>Specialized roles with<br />constrained authority</h2>
        <p>Each agent has a defined scope of action. No single agent has unchecked authority. The separation of proposing, executing, verifying, and reviewing prevents the failure modes of monolithic AI coding tools.</p>
      </div>

      <div class="agents-grid">
        {agents.map(a => (
          <div class="agent-card">
            <div class="agent-card__header">
              <h3 class="agent-card__name">{a.name}</h3>
              <span class="badge">{a.role}</span>
            </div>
            <p class="agent-card__desc">{a.description}</p>
            <div class="agent-card__authority">
              <span class="authority-label">Authority:</span> {a.authority}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Context Engineering -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-header__label">Context Engineering</span>
        <h2>The right information at<br />the right time</h2>
        <p>Every agent invocation is preceded by policy-driven context assembly. The Context Engineer ensures each role has the information it needs — and only what it needs — within a managed token budget.</p>
      </div>

      <!-- Context Engineering Pipeline Visual -->
      <div class="ce-pipeline">
        <div class="ce-stage">
          <div class="ce-stage__node ce-stage__node--input">
            <div class="ce-stage__diamond"></div>
            <span class="ce-stage__label">Policy Registry</span>
          </div>
          <div class="ce-stage__detail">
            <span class="ce-detail-tag">role:phase:subPhase</span>
            <p>Look up required and optional blocks, shedding priority, section budgets</p>
          </div>
        </div>

        <div class="ce-connector">
          <div class="ce-connector__line"></div>
          <span class="ce-connector__arrow">&#9662;</span>
        </div>

        <div class="ce-stage">
          <div class="ce-stage__node">
            <div class="ce-stage__diamond"></div>
            <span class="ce-stage__label">Context Engineer</span>
          </div>
          <div class="ce-stage__steps">
            <div class="ce-step"><span class="ce-step__bullet"></span>Gather handoff documents</div>
            <div class="ce-step"><span class="ce-step__bullet"></span>Query database (claims, verdicts, decisions)</div>
            <div class="ce-step"><span class="ce-step__bullet"></span>Invoke Deep Research Memory Agent</div>
            <div class="ce-step"><span class="ce-step__bullet"></span>Apply token budgets per section</div>
            <div class="ce-step"><span class="ce-step__bullet"></span>Shed lowest-priority blocks if over budget</div>
          </div>
        </div>

        <div class="ce-connector">
          <div class="ce-connector__line"></div>
          <span class="ce-connector__arrow">&#9662;</span>
        </div>

        <div class="ce-stage">
          <div class="ce-stage__node ce-stage__node--output">
            <div class="ce-stage__diamond"></div>
            <span class="ce-stage__label">HandoffPacket</span>
          </div>
          <div class="ce-stage__detail">
            <p>Structured briefing delivered to downstream agent with section manifest, token accounting, and omission report</p>
          </div>
        </div>
      </div>

      <div class="grid grid--2" style="margin-top: var(--space-2xl);">
        <div class="card">
          <h4 class="card__title">Declarative Policies</h4>
          <p class="card__text">Each role:phase:subPhase combination has a registered policy defining required blocks, optional blocks, shedding priority, and section budgets. No ad-hoc prompt construction.</p>
        </div>
        <div class="card">
          <h4 class="card__title">Deep Research Memory</h4>
          <p class="card__text">When policies require historical or evidence-based blocks, the Context Engineer invokes the Deep Research Memory Agent for multi-stage retrieval with conflict detection, supersession tracking, and authority-weighted scoring.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Data Flow -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-header__label">Data Flow</span>
        <h2>Append-only event sourcing<br />with narrative crystallization</h2>
        <p>Every action in JanumiCode produces events in an append-only log. The Narrative Curator crystallizes these into durable memory artifacts. The Deep Research Memory Agent indexes them into a typed, searchable graph.</p>
      </div>

      <!-- Data Flow — 4-stage pipeline -->
      <div class="df-pipeline">
        <!-- Stage 1: Dialogue Events -->
        <div class="df-stage">
          <div class="df-stage__header">
            <span class="df-stage__tag">EVENT SOURCE</span>
            <h4 class="df-stage__title">Dialogue Events</h4>
            <span class="df-stage__subtitle">Append-only log</span>
          </div>
          <div class="df-stage__items">
            <div class="df-item">Agent actions</div>
            <div class="df-item">Human decisions</div>
            <div class="df-item">Claims &amp; verdicts</div>
            <div class="df-item">Gate resolutions</div>
          </div>
        </div>

        <div class="df-arrow">
          <span class="df-arrow__line"></span>
          <span class="df-arrow__head">&#9654;</span>
        </div>

        <!-- Stage 2: Narrative Curator -->
        <div class="df-stage">
          <div class="df-stage__header">
            <span class="df-stage__tag">CRYSTALLIZATION</span>
            <h4 class="df-stage__title">Narrative Curator</h4>
            <span class="df-stage__subtitle">Transforms raw events</span>
          </div>
          <div class="df-stage__items">
            <div class="df-item">Narrative memories</div>
            <div class="df-item">Decision traces</div>
            <div class="df-item">Open loops</div>
          </div>
        </div>

        <div class="df-arrow">
          <span class="df-arrow__line"></span>
          <span class="df-arrow__head">&#9654;</span>
        </div>

        <!-- Stage 3: Memory Substrate -->
        <div class="df-stage">
          <div class="df-stage__header">
            <span class="df-stage__tag">GRAPH STORE</span>
            <h4 class="df-stage__title">Memory Substrate</h4>
            <span class="df-stage__subtitle">Typed objects + graph edges</span>
          </div>
          <div class="df-stage__items">
            <div class="df-item">Claims</div>
            <div class="df-item">Constraints</div>
            <div class="df-item">Assumptions</div>
            <div class="df-item">Decision traces</div>
            <div class="df-item df-item--edge">Typed edges</div>
          </div>
          <div class="df-stage__edge-labels">
            <span>supports</span>
            <span>contradicts</span>
            <span>supersedes</span>
            <span>derived_from</span>
          </div>
        </div>

        <div class="df-arrow">
          <span class="df-arrow__line"></span>
          <span class="df-arrow__head">&#9654;</span>
        </div>

        <!-- Stage 4: Deep Research -->
        <div class="df-stage df-stage--output">
          <div class="df-stage__header">
            <span class="df-stage__tag">OUTPUT</span>
            <h4 class="df-stage__title">Context Packet</h4>
            <span class="df-stage__subtitle">Multi-stage retrieval</span>
          </div>
          <div class="df-stage__items">
            <div class="df-item df-item--highlight">Material memories</div>
            <div class="df-item df-item--highlight">Binding constraints</div>
            <div class="df-item df-item--highlight">Contradictions</div>
            <div class="df-item df-item--highlight">Superseded items</div>
            <div class="df-item df-item--highlight">Open questions</div>
            <div class="df-item df-item--highlight">Coverage assessment</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Governed Stream UI -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-header__label">Interface</span>
        <h2>The Governed Stream</h2>
        <p>A real-time WebView inside VS Code that surfaces every agent action, decision, and human interaction as structured cards — command blocks, MMP cards, phase progress, reasoning reviews, and gate decisions.</p>
      </div>
      <div class="screenshot-placeholder">
        <p>[ Screenshot: Governed Stream UI with command blocks, MMP cards, and phase progress ]</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .agents-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .agent-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: border-color 0.2s;
  }

  .agent-card:hover {
    border-color: var(--color-primary);
  }

  .agent-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .agent-card__name {
    font-size: 1.2rem;
  }

  .agent-card__desc {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .agent-card__authority {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }

  .authority-label {
    font-weight: 600;
    color: var(--color-primary);
  }

  /* ── Context Engineering Pipeline ── */
  .ce-pipeline {
    max-width: 520px;
    margin: 0 auto;
  }

  .ce-stage {
    display: flex;
    gap: var(--space-lg);
    align-items: flex-start;
  }

  .ce-stage__node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    flex-shrink: 0;
    width: 130px;
  }

  .ce-stage__diamond {
    width: 40px;
    height: 40px;
    transform: rotate(45deg);
    border: 2px solid var(--color-primary);
    border-radius: 4px;
    background: rgba(0, 212, 255, 0.06);
    transition: background 0.3s, box-shadow 0.3s;
  }

  .ce-stage:hover .ce-stage__diamond {
    background: rgba(0, 212, 255, 0.12);
    box-shadow: 0 0 20px var(--color-primary-glow);
  }

  .ce-stage__node--input .ce-stage__diamond {
    border-color: #A78BFA;
    background: rgba(167, 139, 250, 0.06);
  }

  .ce-stage__node--output .ce-stage__diamond {
    border-color: var(--color-accent);
    background: rgba(0, 255, 178, 0.06);
  }

  .ce-stage__label {
    font-size: 0.7rem;
    font-weight: 600;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    text-align: center;
  }

  .ce-stage__detail {
    flex: 1;
    padding-top: var(--space-sm);
  }

  .ce-stage__detail p {
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .ce-detail-tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    font-family: var(--font-mono);
    color: var(--color-primary);
    background: rgba(0, 212, 255, 0.08);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: var(--radius-sm);
    padding: 0.15rem 0.5rem;
    margin-bottom: var(--space-sm);
  }

  .ce-stage__steps {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-top: var(--space-sm);
  }

  .ce-step {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .ce-step__bullet {
    display: inline-block;
    width: 6px;
    height: 6px;
    transform: rotate(45deg);
    border: 1.5px solid var(--color-primary);
    border-radius: 1px;
    flex-shrink: 0;
  }

  .ce-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-sm) 0;
    width: 130px;
  }

  .ce-connector__line {
    width: 1px;
    height: 16px;
    background: rgba(0, 212, 255, 0.3);
  }

  .ce-connector__arrow {
    color: var(--color-primary);
    font-size: 0.6rem;
    opacity: 0.6;
  }

  /* ── Data Flow Pipeline ── */
  .df-pipeline {
    display: flex;
    align-items: stretch;
    gap: 0;
    overflow-x: auto;
    padding: var(--space-md) 0;
  }

  .df-stage {
    flex: 1;
    min-width: 200px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .df-stage::before {
    content: '';
    position: absolute;
    top: -1px;
    left: -1px;
    width: 16px;
    height: 16px;
    border-top: 2px solid var(--color-primary);
    border-left: 2px solid var(--color-primary);
    border-radius: var(--radius-lg) 0 0 0;
    opacity: 0.5;
  }

  .df-stage--output {
    border-color: rgba(0, 255, 178, 0.25);
  }

  .df-stage--output::before {
    border-color: var(--color-accent);
  }

  .df-stage__header {
    padding: var(--space-md) var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .df-stage__tag {
    display: inline-block;
    font-size: 0.55rem;
    font-weight: 700;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    margin-bottom: var(--space-xs);
  }

  .df-stage--output .df-stage__tag {
    color: var(--color-accent);
  }

  .df-stage__title {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 2px;
  }

  .df-stage__subtitle {
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .df-stage__items {
    padding: var(--space-sm) var(--space-lg) var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .df-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .df-item::before {
    content: '';
    display: inline-block;
    width: 5px;
    height: 5px;
    transform: rotate(45deg);
    border: 1px solid var(--color-primary);
    border-radius: 1px;
    flex-shrink: 0;
    opacity: 0.5;
  }

  .df-item--edge::before {
    border-color: #A78BFA;
  }

  .df-item--highlight {
    color: var(--color-text);
    font-weight: 500;
  }

  .df-item--highlight::before {
    border-color: var(--color-accent);
    background: var(--color-accent);
    opacity: 0.7;
  }

  .df-stage__edge-labels {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    padding: 0 var(--space-lg) var(--space-md);
  }

  .df-stage__edge-labels span {
    font-size: 0.55rem;
    font-family: var(--font-mono);
    font-weight: 600;
    color: #A78BFA;
    background: rgba(167, 139, 250, 0.08);
    border: 1px solid rgba(167, 139, 250, 0.2);
    border-radius: 3px;
    padding: 0.1rem 0.35rem;
  }

  .df-arrow {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    padding: 0 var(--space-xs);
  }

  .df-arrow__line {
    display: inline-block;
    width: 12px;
    height: 1px;
    background: rgba(0, 212, 255, 0.3);
  }

  .df-arrow__head {
    color: var(--color-primary);
    font-size: 0.6rem;
    opacity: 0.5;
  }

  .screenshot-placeholder {
    background: var(--color-bg-card);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4xl);
    text-align: center;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .agents-grid {
      grid-template-columns: 1fr;
    }
    .ce-stage {
      flex-direction: column;
    }
    .ce-stage__node {
      width: auto;
    }
    .ce-connector {
      width: auto;
    }
    .df-pipeline {
      flex-direction: column;
    }
    .df-arrow {
      justify-content: center;
      padding: var(--space-sm) 0;
      transform: rotate(90deg);
    }
    .df-stage {
      min-width: auto;
    }
  }
</style>
