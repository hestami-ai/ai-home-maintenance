{
  // VS Code Extension Development Host configurations for JanumiCode v2.
  //
  // The first positional arg in `args` is the folder the dev host opens as
  // its active workspace. We always point it at v2's own `test-workspace/`
  // so state from v1 sessions (which live under JanumiCode/janumicode/
  // test-workspace) never leaks in, and so the sidecar writes its sqlite
  // database somewhere predictable and gitignored.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/test-workspace",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "build",
      "sourceMaps": true,
      "env": {
        "NODE_OPTIONS": "--trace-deprecation"
      }
    },
    {
      "name": "Run Extension (Watch)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/test-workspace",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "watch",
      "sourceMaps": true,
      "env": {
        "NODE_OPTIONS": "--trace-deprecation"
      }
    },
    {
      "name": "Run Extension (Clean — no workspace)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "build",
      "sourceMaps": true,
      "env": {
        "NODE_OPTIONS": "--trace-deprecation"
      }
    }
  ]
}
