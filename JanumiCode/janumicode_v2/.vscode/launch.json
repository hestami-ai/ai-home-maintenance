{
  // VS Code Extension Development Host configurations for JanumiCode v2.
  //
  // The first positional arg in `args` is the folder the dev host opens as
  // its active workspace. We always point it at v2's own
  // `test-and-evaluation/test-workspace/` so state from v1 sessions (which
  // live under JanumiCode/janumicode/test-workspace) never leaks in, and so
  // the sidecar writes its sqlite database somewhere predictable and
  // gitignored.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/test-and-evaluation/test-workspace",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "build",
      "sourceMaps": true,
      "env": {
        "NODE_OPTIONS": "--trace-deprecation"
      }
    },
    {
      "name": "Run Extension (Watch)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/test-and-evaluation/test-workspace",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "watch",
      "sourceMaps": true,
      "env": {
        "NODE_OPTIONS": "--trace-deprecation"
      }
    },
    {
      "name": "Run Extension (Clean — no workspace)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "build",
      "sourceMaps": true,
      "env": {
        "NODE_OPTIONS": "--trace-deprecation"
      }
    },
    {
      // Drive a full Phase 0→10 pipeline through the live extension
      // using the JANUMICODE_E2E test-hook commands. Breakpoints in
      // ClientLiaisonAgent / OrchestratorEngine / phase handlers / the
      // testHooks module all trigger naturally because everything runs
      // in the Extension Development Host's debugger.
      //
      // Default intent: the todo CLI app (short, fast in mock mode).
      // Override JANUMICODE_HARNESS_INTENT in the env block or via a
      // compound-task launcher for Hestami or any other corpus.
      "name": "Debug Harness in Extension Host (mock)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/test-and-evaluation/test-workspace",
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/out/test/e2e/harness-suite"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js",
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "test:e2e:compile",
      "sourceMaps": true,
      "env": {
        "JANUMICODE_E2E": "1",
        "JANUMICODE_AUTOSHOW_LOGS": "0",
        "JANUMICODE_LLM_PROVIDER": "mock",
        "JANUMICODE_HARNESS_INTENT": "Build a simple CLI todo app with add, list, and complete commands, and JSON file persistence.",
        "JANUMICODE_HARNESS_GAP_PATH": "${workspaceFolder}/test-and-evaluation/test-workspace/.janumicode/harness-gap.json",
        "JANUMICODE_HARNESS_TIMEOUT_MS": "60000"
      }
    },
    {
      // Same as above but flipped to real-mode LLM calls + Claude Code
      // CLI parser registration. Preconditions: Ollama reachable,
      // `claude` on PATH, fresh test-workspace so writes don't collide.
      // Timeout bumped to 1h to accommodate Phase 1-8 Ollama synthesis
      // + Phase 9 coding agent writes.
      "name": "Debug Harness in Extension Host (real — todo)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/test-and-evaluation/test-workspace",
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/out/test/e2e/harness-suite"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js",
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "test:e2e:compile",
      "sourceMaps": true,
      "env": {
        "JANUMICODE_E2E": "1",
        "JANUMICODE_AUTOSHOW_LOGS": "0",
        "JANUMICODE_LLM_PROVIDER": "ollama",
        "JANUMICODE_HARNESS_INTENT": "Build a simple CLI todo app with add, list, and complete commands, and JSON file persistence.",
        "JANUMICODE_HARNESS_GAP_PATH": "${workspaceFolder}/test-and-evaluation/test-workspace/.janumicode/harness-gap.json",
        "JANUMICODE_HARNESS_REAL_PHASE9": "1",
        "JANUMICODE_HARNESS_TIMEOUT_MS": "3600000",
        "JANUMICODE_CLAUDE_SKIP_PERMISSIONS": "1"
      }
    },
    {
      // GPU-FREE REPLAY (snapshot path). Opens the extension against a prepared
      // cal-40 clone and streams the whole run into the webview — reproduces
      // (pre-fix) / validates (post-fix) the governed-stream memory behaviour on
      // the snapshot load. NO GPU/LLM/CLI calls are made (fail-loud providers +
      // gpuGuard). Prepare the clone first:
      //   node scripts/replay/prep-replay-db.mjs \
      //     --src <cal-40 test-harness/*.db> \
      //     --dest test-and-evaluation/replay-fixtures/cal-40/clone.db
      "name": "Run Extension (Replay cal-40 — snapshot)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/test-and-evaluation/test-workspace",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "build",
      "sourceMaps": true,
      "env": {
        "JANUMICODE_AUTOSHOW_LOGS": "0",
        "JANUMICODE_REPLAY_MODE": "1",
        "JANUMICODE_REPLAY_DB": "${workspaceFolder}/test-and-evaluation/replay-fixtures/cal-40/clone.db"
      }
    },
    {
      // GPU-FREE REPLAY (live-append path). Starts the view EMPTY and feeds the
      // recorded run's records over time via the ReplayDriver — exercises the
      // store's per-record add() hot path exactly as a live run would, the real
      // O(n^2) trigger the pagination fix targets. Same prepared clone as above.
      "name": "Run Extension (Replay cal-40 — live append)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/test-and-evaluation/test-workspace",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "build",
      "sourceMaps": true,
      "env": {
        "JANUMICODE_AUTOSHOW_LOGS": "0",
        "JANUMICODE_REPLAY_MODE": "1",
        "JANUMICODE_REPLAY_DB": "${workspaceFolder}/test-and-evaluation/replay-fixtures/cal-40/clone.db",
        "JANUMICODE_REPLAY_APPEND": "1",
        "JANUMICODE_REPLAY_APPEND_INTERVAL_MS": "12",
        "JANUMICODE_REPLAY_APPEND_BATCH": "3"
      }
    }
  ]
}
