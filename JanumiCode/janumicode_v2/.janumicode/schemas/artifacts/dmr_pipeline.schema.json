{
  "$id": "janumicode:dmr_pipeline:1.0",
  "title": "Deep Memory Research Pipeline",
  "description": "Container record for a Deep Memory Research invocation — one record covers all 7 stages (LLM-backed + deterministic) with per-stage status, timing, and links to detail records. Introduced because Stages 2-6 are deterministic and previously emitted no governed-stream records, making the pipeline look like it jumped from Stage 1 to Stage 7 in the webview.",
  "type": "object",
  "required": ["kind", "pipeline_id", "requesting_agent_role", "scope_tier", "query", "stages"],
  "properties": {
    "kind": { "const": "dmr_pipeline" },
    "pipeline_id": { "type": "string" },
    "requesting_agent_role": { "type": "string" },
    "scope_tier": { "type": "string" },
    "query": { "type": "string" },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "name", "kind", "status"],
        "properties": {
          "stage": { "type": "integer", "minimum": 1, "maximum": 7 },
          "name": { "type": "string" },
          "kind": { "type": "string", "enum": ["llm", "deterministic", "skipped"] },
          "status": { "type": "string", "enum": ["pending", "running", "completed", "failed"] },
          "started_at": { "type": ["string", "null"] },
          "completed_at": { "type": ["string", "null"] },
          "output_summary": { "type": "string" },
          "output_record_id": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    "completeness_status": { "type": "string" },
    "retrieval_brief_record_id": { "type": "string" }
  }
}
