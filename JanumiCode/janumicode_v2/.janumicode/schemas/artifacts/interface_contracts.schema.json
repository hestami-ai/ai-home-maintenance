          "data_format": { "type": "string" },
          "auth_mechanism": { "type": "string" },
          "error_handling_strategy": { "type": "string" },
          "error_responses": { "type": "array", "minItems": 1, "items": { "type": "object" } }
        }
      }
    }
  }
}
