{
  "$id": "janumicode:implementation_plan:1.0",
  "title": "Implementation Plan",
  "type": "object",
  "required": ["tasks"],
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "task_type", "component_id", "component_responsibility", "description", "backing_tool", "completion_criteria"],
        "properties": {
          "id": { "type": "string" },
          "task_type": { "type": "string", "enum": ["standard", "refactoring"] },
          "component_id": { "type": "string" },
          "component_responsibility": { "type": "string" },
          "description": { "type": "string" },
          "technical_spec_ids": { "type": "array", "items": { "type": "string" } },
          "backing_tool": { "type": "string" },
          "dependency_task_ids": { "type": "array", "items": { "type": "string" } },
          "estimated_complexity": { "type": "string", "enum": ["low", "medium", "high"] },
          "complexity_flag": { "type": "string" },
          "completion_criteria": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object",
              "required": ["criterion_id", "description", "verification_method"],
              "properties": {
                "criterion_id": { "type": "string" },
                "description": { "type": "string" },
                "verification_method": { "type": "string", "enum": ["schema_check", "invariant", "output_comparison", "test_execution"] },
                "artifact_ref": { "type": "string" }
              }
            }
          },
          "write_directory_paths": { "type": "array", "items": { "type": "string" } },
          "read_directory_paths": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "total_tasks": { "type": "integer" },
    "complexity_flagged_count": { "type": "integer" },
    "refactoring_tasks_included": { "type": "boolean" }
  }
}
