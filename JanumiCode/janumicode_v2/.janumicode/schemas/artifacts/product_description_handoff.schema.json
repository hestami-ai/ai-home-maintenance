{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "product_description_handoff.schema.json",
  "title": "ProductDescriptionHandoff",
  "description": "Phase 1 product-lens handoff artifact. Produced at Sub-Phase 1.6 under the product lens by consolidating Intent Discovery (1.0b) + four bloom rounds (1.2 domains/personas, 1.3 journeys/workflows, 1.4 entities, 1.5 integrations/QAs). Shape mirrors v1's IntakePlanDocument.finalizedPlan so the v1 gold reference is directly usable.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "requestCategory",
    "productVision",
    "productDescription",
    "summary",
    "personas",
    "userJourneys",
    "phasingStrategy",
    "successMetrics",
    "businessDomainProposals",
    "entityProposals",
    "workflowProposals",
    "integrationProposals",
    "qualityAttributes",
    "uxRequirements",
    "requirements",
    "decisions",
    "constraints",
    "openQuestions",
    "technicalConstraints",
    "complianceExtractedItems",
    "vvRequirements",
    "canonicalVocabulary",
    "humanDecisions",
    "openLoops"
  ],
  "properties": {
    "kind": { "type": "string", "const": "product_description_handoff" },
    "schemaVersion": { "type": "string", "enum": ["1.0", "1.1"] },
    "requestCategory": { "type": "string", "const": "product_or_feature" },

    "productVision": { "type": "string", "minLength": 1 },
    "productDescription": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },

    "personas": {
      "type": "array",
      "items": { "$ref": "#/definitions/Persona" }
    },
    "userJourneys": {
      "type": "array",
      "items": { "$ref": "#/definitions/UserJourney" }
    },
    "phasingStrategy": {
      "type": "array",
      "items": { "$ref": "#/definitions/PhasingPhase" }
    },
    "successMetrics": { "type": "array", "items": { "type": "string" } },
    "businessDomainProposals": {
      "type": "array",
      "items": { "$ref": "#/definitions/BusinessDomain" }
    },
    "entityProposals": {
      "type": "array",
      "items": { "$ref": "#/definitions/Entity" }
    },
    "workflowProposals": {
      "type": "array",
      "items": { "$ref": "#/definitions/Workflow" }
    },
    "integrationProposals": {
      "type": "array",
      "items": { "$ref": "#/definitions/Integration" }
    },
    "qualityAttributes": { "type": "array", "items": { "type": "string" } },
    "uxRequirements": { "type": "array", "items": { "type": "string" } },

    "requirements": {
      "type": "array",
      "items": { "$ref": "#/definitions/ExtractedItem" }
    },
    "decisions": {
      "type": "array",
      "items": { "$ref": "#/definitions/ExtractedItem" }
    },
    "constraints": {
      "type": "array",
      "items": { "$ref": "#/definitions/ExtractedItem" }
    },
    "openQuestions": {
      "type": "array",
      "items": { "$ref": "#/definitions/ExtractedItem" }
    },

    "technicalConstraints": {
      "type": "array",
      "items": { "$ref": "#/definitions/TechnicalConstraint" }
    },
    "complianceExtractedItems": {
      "type": "array",
      "items": { "$ref": "#/definitions/ExtractedItem" }
    },
    "vvRequirements": {
      "type": "array",
      "items": { "$ref": "#/definitions/VVRequirement" }
    },
    "canonicalVocabulary": {
      "type": "array",
      "items": { "$ref": "#/definitions/VocabularyTerm" }
    },

    "humanDecisions": {
      "type": "array",
      "items": { "$ref": "#/definitions/HumanDecisionSummary" }
    },
    "openLoops": {
      "type": "array",
      "items": { "$ref": "#/definitions/OpenLoop" }
    }
  },

  "definitions": {
    "ProductItemSource": {
      "type": "string",
      "enum": ["user-specified", "document-specified", "ai-proposed", "domain-standard", "synthesized"]
    },

    "Persona": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description", "goals", "painPoints"],
      "properties": {
        "id": { "type": "string", "pattern": "^P-[0-9]+$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "goals": { "type": "array", "items": { "type": "string" } },
        "painPoints": { "type": "array", "items": { "type": "string" } },
        "source": { "$ref": "#/definitions/ProductItemSource" }
      }
    },

    "UserJourneyStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stepNumber", "actor", "action", "expectedOutcome"],
      "properties": {
        "stepNumber": { "type": "integer", "minimum": 1 },
        "actor": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "expectedOutcome": { "type": "string", "minLength": 1 }
      }
    },

    "UserJourney": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "personaId", "title", "scenario", "steps", "acceptanceCriteria", "implementationPhase"],
      "properties": {
        "id": { "type": "string", "pattern": "^UJ-[0-9]+$" },
        "personaId": { "type": "string" },
        "title": { "type": "string" },
        "scenario": { "type": "string" },
        "steps": { "type": "array", "items": { "$ref": "#/definitions/UserJourneyStep" } },
        "acceptanceCriteria": { "type": "array", "items": { "type": "string" } },
        "implementationPhase": { "type": "string" },
        "priority": { "type": "string" },
        "source": { "$ref": "#/definitions/ProductItemSource" }
      }
    },

    "PhasingPhase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "description", "journeyIds", "rationale"],
      "properties": {
        "phase": { "type": "string" },
        "description": { "type": "string" },
        "journeyIds": { "type": "array", "items": { "type": "string" } },
        "rationale": { "type": "string" }
      }
    },

    "BusinessDomain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description", "rationale", "entityPreview", "workflowPreview"],
      "properties": {
        "id": { "type": "string", "pattern": "^DOM-[A-Z0-9_-]+$" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "rationale": { "type": "string" },
        "entityPreview": { "type": "array", "items": { "type": "string" } },
        "workflowPreview": { "type": "array", "items": { "type": "string" } },
        "source": { "$ref": "#/definitions/ProductItemSource" }
      }
    },

    "Entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "businessDomainId", "name", "description", "keyAttributes", "relationships"],
      "properties": {
        "id": { "type": "string", "pattern": "^ENT-[A-Z0-9_-]+$" },
        "businessDomainId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "keyAttributes": { "type": "array", "items": { "type": "string" } },
        "relationships": { "type": "array", "items": { "type": "string" } },
        "source": { "$ref": "#/definitions/ProductItemSource" }
      }
    },

    "Workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "businessDomainId", "name", "description", "steps", "triggers", "actors"],
      "properties": {
        "id": { "type": "string", "pattern": "^WF-[0-9]+$" },
        "businessDomainId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "string" } },
        "triggers": { "type": "array", "items": { "type": "string" } },
        "actors": { "type": "array", "items": { "type": "string" } },
        "source": { "$ref": "#/definitions/ProductItemSource" }
      }
    },

    "Integration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "category", "description", "standardProviders", "ownershipModel", "rationale"],
      "properties": {
        "id": { "type": "string", "pattern": "^INT-[A-Z0-9_-]+$" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "standardProviders": { "type": "array", "items": { "type": "string" } },
        "ownershipModel": {
          "type": "string",
          "enum": ["delegated", "synced", "consumed", "owned"]
        },
        "rationale": { "type": "string" },
        "source": { "$ref": "#/definitions/ProductItemSource" }
      }
    },

    "ExtractedItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "text", "timestamp"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["REQUIREMENT", "DECISION", "CONSTRAINT", "OPEN_QUESTION"]
        },
        "text": { "type": "string", "minLength": 1 },
        "extractedFromTurnId": { "type": "integer", "minimum": 0 },
        "timestamp": { "type": "string", "format": "date-time" },
        "source_ref": { "$ref": "#/definitions/SourceRef" }
      }
    },

    "SourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_path", "excerpt"],
      "properties": {
        "document_path": { "type": "string", "minLength": 1 },
        "section_heading": { "type": "string" },
        "excerpt": { "type": "string", "minLength": 1 },
        "excerpt_start": { "type": "integer", "minimum": 0 },
        "excerpt_end": { "type": "integer", "minimum": 0 }
      }
    },

    "TechnicalConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "category", "text"],
      "properties": {
        "id": { "type": "string", "pattern": "^TECH-[0-9]+$" },
        "category": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "technology": { "type": "string" },
        "version": { "type": "string" },
        "rationale": { "type": "string" },
        "source_ref": { "$ref": "#/definitions/SourceRef" }
      }
    },

    "VVRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "category", "target", "measurement"],
      "properties": {
        "id": { "type": "string", "pattern": "^VV-[0-9]+$" },
        "category": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "measurement": { "type": "string", "minLength": 1 },
        "threshold": { "type": "string" },
        "source_ref": { "$ref": "#/definitions/SourceRef" }
      }
    },

    "VocabularyTerm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "term", "definition"],
      "properties": {
        "id": { "type": "string", "pattern": "^VOC-[0-9]+$" },
        "term": { "type": "string", "minLength": 1 },
        "definition": { "type": "string", "minLength": 1 },
        "synonyms": { "type": "array", "items": { "type": "string" } },
        "source_ref": { "$ref": "#/definitions/SourceRef" }
      }
    },

    "HumanDecisionSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "sub_phase_id", "target_id"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["accepted", "rejected", "edited", "deferred"]
        },
        "sub_phase_id": { "type": "string" },
        "target_id": { "type": "string" },
        "rationale": { "type": "string" }
      }
    },

    "OpenLoop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "description", "priority"],
      "properties": {
        "category": {
          "type": "string",
          "enum": ["deferred_decision", "missing_info", "unresolved_risk", "followup"]
        },
        "description": { "type": "string" },
        "priority": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      }
    }
  }
}
