{
  
  "$id": "janumicode:intent_statement:1.0",
  "title": "Intent Statement",
  "description": "Sub-Phase 1.4 output — locked, unambiguous specification of human intent",
  "type": "object",
  "required": ["product_concept", "confirmed_assumptions", "confirmed_constraints", "out_of_scope"],
  "properties": {
    "product_concept": {
      "type": "object",
      "required": ["name", "description", "who_it_serves", "problem_it_solves"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "who_it_serves": { "type": "string", "minLength": 1 },
        "problem_it_solves": { "type": "string", "minLength": 1 }
      }
    },
    "confirmed_assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["assumption", "confirmed_by_record_id"],
        "properties": {
          "assumption": { "type": "string" },
          "confirmed_by_record_id": { "type": "string" }
        }
      }
    },
    "confirmed_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["constraint", "type"],
        "properties": {
          "constraint": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["technical", "business", "regulatory", "preferential"]
          }
        }
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scope_classification_ref": { "type": "string" },
    "compliance_context_ref": { "type": "string" },
    "prior_decision_overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["override_record_id", "prior_decision_record_id"],
        "properties": {
          "override_record_id": { "type": "string" },
          "prior_decision_record_id": { "type": "string" },
          "rationale": { "type": "string" }
        }
      }
    },
    "system_proposed_content_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "content", "approved"],
        "properties": {
          "field": { "type": "string" },
          "content": { "type": "string" },
          "approved": { "type": "boolean" }
        }
      }
    }
  }
}
