{
  "$id": "janumicode:component_model:1.0",
  "title": "Component Model",
  "type": "object",
  "required": ["components"],
  "properties": {
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "responsibilities"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "domain_id": { "type": "string" },
          "responsibilities": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "statement"],
              "properties": {
                "id": { "type": "string" },
                "statement": { "type": "string" }
              }
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["target_component_id", "dependency_type"],
              "properties": {
                "target_component_id": { "type": "string" },
                "dependency_type": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
