[37m[39;120Hirectory)[m

[37m```[38;5;9mtypescript[m
[35mimport [37m{ Pool, Client } [35mfrom [37m'[32m@shared/lib/db[37m'; [38;5;8m// PostgreSQL connection pool/client adapter[K[m
[37m[2C[m
[35mexport class [33mClickCounterInitializer [35mimplements [32mLinkInitializerInterface [38;5;15m{[K[m
[38;5;15m  [35mconstructor[37m([35mprivate readonly [37mdbPool: [31mPool [37m| [31mClient[37m) [38;5;15m{}[K[m
[38;5;15m[2C[m
[38;5;15m  [35masync [34minitialize[37m(mappingIdOrSlug: [38;5;15mstring[37m): [31mPromise[38;5;15m<void> {[K[m
[38;5;15m    [35mconst [37mquery = `[32mUPDATE links SET click_count=0[K[1C[m
[32m                   WHERE mapping_id=$1 AND click_count IS NULL[37m` +[K[m
[38;5;15m[19X[37m[19C' [32mON CONFLICT (mapping_slug) DO NOTHING[37m'[38;5;15m; [38;5;8m// or INSERT IF NOT EXISTS pattern[m
[38;5;15m[2C[m
[38;5;15m    [35mreturn [37mthis[38;5;15m.[37mdbPool[38;5;15m.[34mquery[38;5;15m([37mquery[38;5;15m, [[37mmappingIdOrSlug[38;5;15m]);[K[m
[38;5;15m  }[m
[38;5;15m}[m
[37m```[m

