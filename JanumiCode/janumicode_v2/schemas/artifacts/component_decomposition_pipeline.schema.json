{
  "$id": "janumicode:component_decomposition_pipeline:1.0",
  "title": "Component Decomposition Pipeline",
  "description": "Wave 7 — container card for a recursive component decomposition. One record per root component; passes[] grows incrementally as recursion proceeds. final_* fields populated when pipeline reaches terminal status.",
  "type": "object",
  "required": ["kind", "pipeline_id", "root_component_id", "passes"],
  "properties": {
    "kind": { "const": "component_decomposition_pipeline" },
    "pipeline_id": { "type": "string" },
    "root_component_id": { "type": "string" },
    "passes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pass_number", "status", "started_at", "completed_at", "nodes_produced", "assumption_delta"],
        "properties": {
          "pass_number": { "type": "integer", "minimum": 0 },
          "status": { "type": "string", "enum": ["pending", "running", "completed", "terminated"] },
          "started_at": { "type": ["string", "null"] },
          "completed_at": { "type": ["string", "null"] },
          "nodes_produced": { "type": "integer", "minimum": 0 },
          "assumption_delta": { "type": "integer", "minimum": 0 },
          "termination_reason": { "type": "string", "enum": ["fixed_point", "depth_cap", "budget_cap", "fanout_cap", "human_pruned_all"] }
        }
      }
    },
    "final_leaf_count": { "type": "integer", "minimum": 0 },
    "final_max_depth": { "type": "integer", "minimum": 0 },
    "total_llm_calls": { "type": "integer", "minimum": 0 },
    "tier_distribution": {
      "type": "object",
      "properties": {
        "A": { "type": "integer", "minimum": 0 },
        "B": { "type": "integer", "minimum": 0 },
        "C": { "type": "integer", "minimum": 0 },
        "D": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
