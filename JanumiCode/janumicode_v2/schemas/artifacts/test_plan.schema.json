{
  "$id": "janumicode:test_plan:1.0",
  "title": "Test Plan",
  "type": "object",
  "required": ["test_suites"],
  "properties": {
    "test_suites": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["suite_id", "component_id", "test_type", "test_cases"],
        "properties": {
          "suite_id": { "type": "string" },
          "component_id": { "type": "string" },
          "test_type": { "type": "string", "enum": ["unit", "integration", "end_to_end"] },
          "runner_command": { "type": "string" },
          "test_cases": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["test_case_id", "type", "acceptance_criterion_ids", "preconditions", "expected_outcome"],
              "properties": {
                "test_case_id": { "type": "string" },
                "type": { "type": "string", "enum": ["unit", "integration", "end_to_end"] },
                "acceptance_criterion_ids": { "type": "array", "items": { "type": "string" } },
                "component_ids": { "type": "array", "items": { "type": "string" } },
                "preconditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
                "inputs": { "type": "object" },
                "execution_steps": { "type": "array", "items": { "type": "string" } },
                "expected_outcome": { "type": "string" },
                "edge_cases": { "type": "array", "items": { "type": "string" } },
                "implementation_notes": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "total_test_cases": { "type": "integer" },
    "coverage_by_type": {
      "type": "object",
      "properties": {
        "unit": { "type": "integer" },
        "integration": { "type": "integer" },
        "end_to_end": { "type": "integer" }
      }
    }
  }
}
