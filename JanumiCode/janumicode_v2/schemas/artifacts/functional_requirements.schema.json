{
  "$id": "janumicode:functional_requirements:1.0",
  "title": "Functional Requirements",
  "type": "object",
  "required": ["user_stories"],
  "properties": {
    "user_stories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "role", "action", "outcome", "acceptance_criteria", "priority"],
        "properties": {
          "id": { "type": "string" },
          "role": { "type": "string" },
          "action": { "type": "string" },
          "outcome": { "type": "string" },
          "acceptance_criteria": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "description", "measurable_condition"],
              "properties": {
                "id": { "type": "string" },
                "description": { "type": "string" },
                "measurable_condition": { "type": "string" }
              }
            }
          },
          "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] }
        }
      }
    }
  }
}
