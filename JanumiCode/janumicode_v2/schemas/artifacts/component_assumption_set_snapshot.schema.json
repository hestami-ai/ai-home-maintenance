{
  "$id": "janumicode:component_assumption_set_snapshot:1.0",
  "title": "Component Assumption Set Snapshot",
  "description": "Wave 7 — one record per component-decomposition pass capturing the cumulative architectural-assumption set A_n for the component tree being expanded. Termination criterion: pass N writes delta_from_previous_pass === 0 means the decomposition reached fixed-point. Distinct from Phase 2's assumption_set_snapshot — these track architectural assumptions (component boundaries, cross-cutting concern placement, integration patterns) rather than requirement assumptions.",
  "type": "object",
  "required": ["kind", "pass_number", "root_component_id", "assumptions", "delta_from_previous_pass"],
  "properties": {
    "kind": { "const": "component_assumption_set_snapshot" },
    "pass_number": { "type": "integer", "minimum": 0 },
    "root_component_id": { "type": "string" },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "source", "surfaced_at_pass", "category"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "source": { "type": "string", "enum": ["handoff", "domain", "decomposition", "human"] },
          "surfaced_at_node": { "type": "string" },
          "surfaced_at_pass": { "type": "integer", "minimum": 0 },
          "category": {
            "type": "string",
            "enum": [
              "boundary",
              "cross_cutting",
              "integration_pattern",
              "data_ownership",
              "scaling_assumption",
              "tech_choice",
              "open_question"
            ]
          },
          "citations": { "type": "array", "items": { "type": "string" } },
          "duplicate_of": { "type": "string" },
          "duplicate_similarity": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "delta_from_previous_pass": { "type": "integer", "minimum": 0 },
    "semantic_delta": { "type": "integer", "minimum": 0 }
  }
}
