{
  "$id": "janumicode:data_model_assumption_set_snapshot:1.0",
  "title": "Data Model Assumption Set Snapshot",
  "description": "Wave 9 — one record per data-model decomposition pass capturing the cumulative data-design assumption set. Termination criterion: pass with delta_from_previous_pass === 0 means fixed-point reached.",
  "type": "object",
  "required": ["kind", "pass_number", "root_entity_id", "assumptions", "delta_from_previous_pass"],
  "properties": {
    "kind": { "const": "data_model_assumption_set_snapshot" },
    "pass_number": { "type": "integer", "minimum": 0 },
    "root_entity_id": { "type": "string" },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "source", "surfaced_at_pass", "category"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "source": { "type": "string", "enum": ["component", "domain", "decomposition", "human"] },
          "surfaced_at_node": { "type": "string" },
          "surfaced_at_pass": { "type": "integer", "minimum": 0 },
          "category": {
            "type": "string",
            "enum": [
              "identity",
              "ownership",
              "cardinality",
              "lifecycle",
              "consistency",
              "storage_choice",
              "open_question"
            ]
          },
          "citations": { "type": "array", "items": { "type": "string" } },
          "duplicate_of": { "type": "string" },
          "duplicate_similarity": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "delta_from_previous_pass": { "type": "integer", "minimum": 0 },
    "semantic_delta": { "type": "integer", "minimum": 0 }
  }
}
