{
  "$id": "janumicode:data_model_decomposition_pipeline:1.0",
  "title": "Data Model Decomposition Pipeline",
  "description": "Wave 9 — container card for a recursive data-model decomposition (Phase 5.1a). One pipeline per workflow_run; passes[] grows incrementally.",
  "type": "object",
  "required": ["kind", "pipeline_id", "root_entity_id", "passes"],
  "properties": {
    "kind": { "const": "data_model_decomposition_pipeline" },
    "pipeline_id": { "type": "string" },
    "root_entity_id": { "type": "string" },
    "passes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pass_number", "status", "started_at", "completed_at", "nodes_produced", "assumption_delta"],
        "properties": {
          "pass_number": { "type": "integer", "minimum": 0 },
          "status": { "type": "string", "enum": ["pending", "running", "completed", "terminated"] },
          "started_at": { "type": ["string", "null"] },
          "completed_at": { "type": ["string", "null"] },
          "nodes_produced": { "type": "integer", "minimum": 0 },
          "assumption_delta": { "type": "integer", "minimum": 0 },
          "termination_reason": { "type": "string", "enum": ["fixed_point", "depth_cap", "budget_cap", "fanout_cap", "human_pruned_all", "diverging", "dedup_offline"] }
        }
      }
    },
    "final_leaf_count": { "type": "integer", "minimum": 0 },
    "final_max_depth": { "type": "integer", "minimum": 0 },
    "total_llm_calls": { "type": "integer", "minimum": 0 },
    "tier_distribution": {
      "type": "object",
      "properties": {
        "A": { "type": "integer", "minimum": 0 },
        "B": { "type": "integer", "minimum": 0 },
        "C": { "type": "integer", "minimum": 0 },
        "D": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
