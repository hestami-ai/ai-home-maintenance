{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://janumi.example/schemas/irp/0.3/program-model.schema.json",
  "title": "IRP Program Model",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "controlSchema": {
      "const": "program-model.schema.json"
    },
    "programModelId": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "phaseStates": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "phaseId",
          "title",
          "outcome",
          "hardPrerequisites"
        ],
        "properties": {
          "phaseId": {
            "type": "string",
            "pattern": "^P[0-9]+$"
          },
          "title": {
            "type": "string"
          },
          "outcome": {
            "type": "string"
          },
          "hardPrerequisites": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "required": [
    "controlSchema",
    "programModelId",
    "version",
    "generatedAt",
    "phaseStates",
    "phases"
  ]
}
