{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://janumi.example/schemas/irp/0.3/current-state-model.schema.json",
  "title": "Current State Model",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "controlSchema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "0.3.0"
    },
    "recordId": {
      "type": "string",
      "minLength": 1
    },
    "recordType": {
      "type": "string",
      "minLength": 1
    },
    "programInstanceId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdBy": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "repositoryRevision": {
      "type": "string"
    },
    "modelElements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "elementId",
          "name",
          "elementType",
          "statementType",
          "confidence",
          "evidenceIds"
        ],
        "properties": {
          "elementId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "elementType": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "statementType": {
            "enum": [
              "OBSERVATION",
              "INTERPRETATION",
              "CONCLUSION",
              "UNKNOWN"
            ]
          },
          "confidence": {
            "enum": [
              "HIGH",
              "MEDIUM",
              "LOW",
              "UNKNOWN",
              "CONFLICTED"
            ]
          },
          "evidenceIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "sourceLocations": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "relationships": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "unknowns": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "reviewStatus": {
            "type": "string"
          }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "unknownId",
          "question",
          "whyMaterial",
          "requiredEvidence",
          "requiredByPhase"
        ],
        "properties": {
          "unknownId": {
            "type": "string"
          },
          "question": {
            "type": "string"
          },
          "whyMaterial": {
            "type": "string"
          },
          "requiredEvidence": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "proposedInvestigation": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "requiredByPhase": {
            "type": "string"
          },
          "currentRisk": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "controlSchema",
    "schemaVersion",
    "recordId",
    "recordType",
    "programInstanceId",
    "version",
    "status",
    "createdAt",
    "createdBy",
    "repositoryRevision",
    "modelElements",
    "unknowns"
  ]
}
