{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "commandId": {
      "type": "string",
      "minLength": 1
    },
    "commandType": {
      "type": "string",
      "minLength": 1
    },
    "commandSchemaVersion": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "targetAggregateType": {
      "type": "string",
      "minLength": 1
    },
    "targetAggregateId": {
      "type": "string",
      "minLength": 1
    },
    "expectedRevision": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "issuedBy": {
      "type": "object",
      "properties": {
        "actorId": {
          "type": "string",
          "minLength": 1
        },
        "actorType": {
          "type": "string",
          "enum": [
            "HUMAN",
            "AGENT",
            "MODEL",
            "SERVICE",
            "POLICY_ENGINE",
            "EXTERNAL_SYSTEM"
          ]
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "roleId": {
          "type": "string"
        },
        "modelId": {
          "type": "string"
        },
        "providerId": {
          "type": "string"
        },
        "executionInstanceId": {
          "type": "string"
        }
      },
      "required": [
        "actorId",
        "actorType",
        "displayName"
      ],
      "additionalProperties": false
    },
    "correlationId": {
      "type": "string",
      "minLength": 1
    },
    "causationId": {
      "type": "string"
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    },
    "payload": {}
  },
  "required": [
    "commandId",
    "commandType",
    "commandSchemaVersion",
    "targetAggregateType",
    "targetAggregateId",
    "issuedAt",
    "issuedBy",
    "correlationId",
    "idempotencyKey",
    "payload"
  ],
  "additionalProperties": false,
  "$id": "urn:janumi:rph:schema:command:DomainCommand:1"
}
