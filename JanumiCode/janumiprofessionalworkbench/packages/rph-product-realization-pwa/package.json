{
  "name": "@janumipwb/rph-product-realization-pwa",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The Product Realization PWA ontology as VERSIONED DATA — PWU Type templates, the seed assurance policies, conformance profiles, and the legacy compatibility-phase mapping. Consumed by the engine; the engine mechanism stays PWA-agnostic.",
  "license": "AGPL-3.0-only",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "gen": "bun run src/gen/gen-ontology.ts",
    "gen:ontology": "bun run src/gen/gen-ontology.ts"
  },
  "dependencies": {
    "@janumipwb/rph-contracts": "workspace:*"
  },
  "devDependencies": {
    "@janumipwb/typescript-config": "workspace:*"
  }
}
