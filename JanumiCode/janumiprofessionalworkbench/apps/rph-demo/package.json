{
  "name": "@janumipwb/rph-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Interactive SvelteKit demonstration workbench for PWA authoring and Undertaking, assurance, Decision, and Baseline views over the RPH engine.",
  "scripts": {
    "dev": "svelte-kit sync && vite dev",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check-types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "prepare": "svelte-kit sync",
    "e2e": "playwright test",
    "e2e:server": "svelte-kit sync && vite dev --host 127.0.0.1 --port 4319 --strictPort",
    "e2e:live": "playwright test --config playwright.live.config.ts",
    "e2e:server:live": "svelte-kit sync && vite dev --host 127.0.0.1 --port 4321 --strictPort"
  },
  "dependencies": {
    "@dagrejs/dagre": "3.0.0",
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@janumipwb/rph-authoring": "workspace:*",
    "@janumipwb/rph-engine": "workspace:*",
    "@janumipwb/rph-product-realization-pwa": "workspace:*",
    "@janumipwb/rph-projections": "workspace:*",
    "@statelyai/graph": "2.1.0",
    "@xstate/svelte": "5.0.0",
    "@xyflow/svelte": "^1.4.0",
    "elkjs": "0.11.1",
    "typebox": "1.1.38",
    "ulid": "^2.3.0",
    "xstate": "5.32.5"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@sveltejs/adapter-auto": "^6.0.0",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.0.0"
  }
}
