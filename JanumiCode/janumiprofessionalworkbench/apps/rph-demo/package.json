{
  "name": "@janumipwb/rph-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "M14 demonstration UI — a SvelteKit + Svelte Flow surface that visualizes the RPH PWU decomposition (4 state axes, no-green-without-assurance) over the pure rph-projections read-model seam (never the Node engine facade). Run from the repo root with: bun install && bun run --filter @janumipwb/rph-demo dev  (this monorepo pins Bun via devEngines; npm will refuse). Or from this dir: bun run dev.",
  "scripts": {
    "dev": "svelte-kit sync && vite dev",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "prepare": "svelte-kit sync",
    "e2e": "playwright test",
    "e2e:server": "svelte-kit sync && vite dev --host 127.0.0.1 --port 4319 --strictPort",
    "e2e:live": "playwright test --config playwright.live.config.ts",
    "e2e:server:live": "svelte-kit sync && vite dev --host 127.0.0.1 --port 4321 --strictPort"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@janumipwb/rph-authoring": "workspace:*",
    "@janumipwb/rph-engine": "workspace:*",
    "@janumipwb/rph-product-realization-pwa": "workspace:*",
    "@janumipwb/rph-projections": "workspace:*",
    "@xyflow/svelte": "^1.4.0",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@sveltejs/adapter-auto": "^6.0.0",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.0.0"
  }
}
