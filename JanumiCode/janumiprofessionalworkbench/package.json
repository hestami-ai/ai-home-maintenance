{
  "name": "janumi-professional-workbench",
  "private": true,
  "type": "module",
  "description": "Janumi Professional Workbench (JPWB) — the Recursive Professional Harness (RPH) engine, a host-agnostic TypeScript core library.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "lint": "eslint .",
    "test": "turbo run test",
    "gen": "turbo run gen",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "boundary": "depcruise packages --config .dependency-cruiser.cjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@janumipwb/typescript-config": "workspace:*",
    "@types/node": "^24.0.0",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.37.0",
    "globals": "^15.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.10.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
