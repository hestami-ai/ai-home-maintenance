            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Phase 0 Gate": {
      "main": [
        [
          {
            "node": "Human Approval Gate",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
