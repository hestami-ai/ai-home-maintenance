{
  "name": "janumilegal",
  "displayName": "JanumiLegal",
  "description": "Lens-driven legal AI production harness with deterministic state-machine governance, source-to-claim traceability, and attorney-controlled release.",
  "version": "0.1.0",
  "publisher": "hestami-ai",
  "private": true,
  "engines": {
    "vscode": "^1.109.0",
    "node": ">=22"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "janumilegal.openMatterDashboard",
        "title": "JanumiLegal: Open Matter Dashboard"
      },
      {
        "command": "janumilegal.switchMatter",
        "title": "JanumiLegal: Switch Active Matter"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "janumilegal-sidebar",
          "title": "JanumiLegal",
          "icon": "$(law)"
        }
      ]
    },
    "views": {
      "janumilegal-sidebar": [
        {
          "id": "janumilegal.matterDashboard",
          "name": "Matter",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc --noEmit && node esbuild.js",
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src/",
    "lint:layers": "tsx scripts/lintLayers.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "calibration": "tsx scripts/runCalibration.ts",
    "audit:hardcoding": "tsx scripts/runHardcodingAudit.ts",
    "thin-slice:run": "tsx scripts/initThinSliceRun.ts",
    "thin-slice:review": "tsx scripts/thinSliceReview.ts",
    "red-team:corpus": "tsx scripts/runRedTeamCorpus.ts",
    "ci": "pnpm typecheck && pnpm lint && pnpm lint:layers && pnpm audit:hardcoding && pnpm test && pnpm calibration && pnpm red-team:corpus && pnpm build"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "esbuild": "^0.28.0",
    "esbuild-svelte": "^0.9.4",
    "eslint": "^10.2.0",
    "svelte": "^5.55.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
