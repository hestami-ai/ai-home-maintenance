# Historian Agent Platform - Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# vLLM Configuration
# =============================================================================

# Internal API key for vLLM authentication
VLLM_API_KEY=local-historian-key

# Logging level for vLLM service
VLLM_LOG_LEVEL=INFO

# =============================================================================
# Dolt Configuration
# =============================================================================

# Dolt database credentials (default root user with no password)
DOLT_USER=root
DOLT_PASSWORD=
DOLT_DATABASE=dolt

# =============================================================================
# General Configuration
# =============================================================================

# Logging level for all services (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# Model Configuration (for development)
# =============================================================================

# Path to model weights (relative to project root)
# The Qwen3-14B model should be placed in ./models/qwen3-14b/
# MODEL_PATH=./models/qwen3-14b
